import PSB2 (extract_train_data, load_dataset)

def __internal__train: TrainData := extract_train_data (load_dataset "gcd" 200 200)

def __internal__calculate_gcd_errors : (__internal__train : TrainData) -> (f:(a: Int) -> (b: Int) -> Int)  -> List  :=  fun data => fun func => native "[abs(func(x[0])(x[1]) - y[0]) for x, y  in data]"

#@allow_recursion
@multi_minimize_float(__internal__calculate_gcd_errors __internal__train synth, 1)
def synth (n:Int) (z:Int) : Int := (let extract_train_data := unit in let load_dataset := unit in ?hole)
