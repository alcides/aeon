import PSB2 (extract_train_data, load_dataset)

def train: TrainData := extract_train_data (load_dataset "gcd" 200 200)

def calculate_gcd_errors : (train : TrainData) -> (f:(a: Int) -> (b: Int) -> Int)  -> List  :=  fun data => fun func => native "[abs(func(x[0])(x[1]) - y[0]) for x, y  in data]"

#@allow_recursion
@multi_minimize_float(calculate_gcd_errors train synth, 1)
def synth (n:Int) (z:Int) : Int := (let extract_train_data := unit in let load_dataset := unit in let train := unit in let calculate_fuel_cost_errors := unit in ?hole)
