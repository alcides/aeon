import PSB2 (extract_train_data, load_dataset)

def String_len : (i:String) -> Int := fun i => native "len(i)"
def String_intToString : (i:Int) -> String := fun i => native "str(i)"

def String_concat : (i:String) -> (j:String) -> String := fun i => fun j => native "i + j"

def const1 : String := "You didn't type anything"
def const2 : String := "Too many characters"
def const3 : String := "Your tweet has "
def const4 : String := " characters"


def train: TrainData := extract_train_data (load_dataset "twitter" 200 200)


def calculate_twitter_errors : (train : TrainData) -> (f:(a: String) -> String)  -> List  :=  fun data => fun func => native "[__import__('textdistance').levenshtein(func(x[0]), y[0]) for x , y in data]"


@multi_minimize_float(calculate_twitter_errors train synth, 1)
def synth (tweet: String) : String := (let extract_train_data := unit in let load_dataset := unit in let calculate_twitter_errors := unit in let train := unit in ?hole)
