# Benchmark: synthesize (Maybe Int) toward some 42 using polymorphic inductive Maybe.

inductive Maybe a
| nothing : (Maybe a)
| some (x:a) : (Maybe a)

def read (m:(Maybe a)) (d:a) : a {
    Maybe_rec m d (\x -> x)
}

def abs (n:Int) : Int {
    if n < 0 then 0 - n else n
}

@minimize_int(abs(read result 100 - 42))
def result : (Maybe Int) = ?hole;
