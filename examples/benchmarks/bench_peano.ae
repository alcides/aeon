# Benchmark: synthesize the Peano representation of 5 using Zero and Succ.
# Zero and Succ are the only constructors; nat_val converts to Int for the fitness.
# The synthesizer must nest exactly 5 Succ applications around Zero.

type Nat;

def Zero : Nat = native "0";
def Succ (n:Nat) : Nat = native "n + 1";
def nat_val (n:Nat) : Int = native "n";

def abs (n:Int) : Int {
    if n < 0 then 0 - n else n
}

@minimize_int(abs(nat_val result - 5))
def result : Nat = ?hole;
