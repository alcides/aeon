# Problem 2: Find the second-to-last element of a list.
# Refinement requires at least two elements.

open Array

def secondLast (l: {x:(Array a) | Array.size x > 1}) : a = native "l[-2]"

def main (args:Int) : Unit =
    xs = Array.append (Array.append (Array.append (Array.new[Int]) 1) 2) 3;
    print (secondLast xs);
