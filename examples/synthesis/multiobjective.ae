def hard_constraint : (x:Int) -> Bool = uninterpreted

def soft_constraint (n: Int) : Int = (n * n) - 5

def other_soft_constraint (n: Int) : Int = n + 4

@minimize_int(soft_constraint (func 10))
@minimize_int(other_soft_constraint (func 21))
def func (i:Int | i >= 10) : {v:Int | v > 10 }  = ?hole;



def main (args: Int) : Unit = print (func 42)
